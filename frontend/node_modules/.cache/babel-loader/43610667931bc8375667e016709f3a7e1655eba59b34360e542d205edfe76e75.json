p>\r\n        </div>\r\n\r\n        <div className=\"advantages__card\">\r\n          <h3 className=\"advantages__card-title\">\r\n            Профессиональное оборудование\r\n          </h3>\r\n          <p>\r\n            Большой экран, качественная акустика\r\n            и удобные кресла создают настоящий\r\n            эффект кинотеатра.\r\n          </p>\r\n        </div>\r\n\r\n        <div className=\"advantages__card\">\r\n          <h3 className=\"advantages__card-title\">\r\n            Центр города\r\n          </h3>\r\n          <p>\r\n            Комната расположена в центре Москвы,\r\n            поэтому до нас легко добраться из\r\n            любой части города.\r\n          </p>\r\n        </div>\r\n\r\n      </div>\r\n\r\n    </section>\r\n  );\r\n}\r\n\r\nexport default Advantages;"],"mappings":"AAAA,MAAO,CAAAA,KAAK,KAAM,OAAO,CACzB,MAAO,kBAAkB,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAE1B,QAAS,CAAAC,UAAUA,CAAA,CAAG,CACpB,mBACED,KAAA,YAASE,SAAS,CAAC,YAAY,CAAAC,QAAA,eAE7BL,IAAA,OAAII,SAAS,CAAC,mBAAmB,CAAAC,QAAA,CAAC,0GAElC,CAAI,CAAC,cAELH,KAAA,QAAKE,SAAS,CAAC,kBAAkB,CAAAC,QAAA,eAE/BH,KAAA,QAAKE,SAAS,CAAC,kBAAkB,CAAAC,QAAA,eAC/BL,IAAA,OAAII,SAAS,CAAC,wBAAwB,CAAAC,QAAA,CAAC,+GAEvC,CAAI,CAAC,cACLL,IAAA,MAAAK,QAAA,CAAG,geAIH,CAAG,CAAC,EACD,CAAC,cAENH,KAAA,QAAKE,SAAS,CAAC,kBAAkB,CAAAC,QAAA,eAC/BL,IAAA,OAAII,SAAS,CAAC,wBAAwB,CAAAC,QAAA,CAAC,2KAEvC,CAAI,CAAC,cACLL,IAAA,MAAAK,QAAA,CAAG,keAIH,CAAG,CAAC,EACD,CAAC,cAENH,KAAA,QAAKE,SAAS,CAAC,kBAAkB,CAAAC,QAAA,eAC/BL,IAAA,OAAII,SAAS,CAAC,wBAAwB,CAAAC,QAAA,CAAC,qEAEvC,CAAI,CAAC,cACLL,IAAA,MAAAK,QAAA,CAAG,mdAIH,CAAG,CAAC,EACD,CAAC,EAEH,CAAC,EAEC,CAAC,CAEd,CAEA,cAAe,CAAAF,UAAU","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}